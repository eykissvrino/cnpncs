generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  username  String    @unique
  password  String
  name      String
  department String
  role      String    @default("user")
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  keywords  Keyword[]
}

model Keyword {
  id        Int           @id @default(autoincrement())
  name      String
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())
  userId    Int?
  user      User?         @relation(fields: [userId], references: [id])
  results   CrawlResult[]

  @@unique([name, userId])
}

model CrawlResult {
  id        Int      @id @default(autoincrement())
  type      String
  title     String
  agency    String
  budget    String?
  deadline  String?
  postDate  String
  bidNumber String?  @unique
  url       String?
  rawData   String
  isNew     Boolean  @default(true)
  notified  Boolean  @default(false)
  keywordId Int?
  keyword   Keyword? @relation(fields: [keywordId], references: [id])
  createdAt DateTime @default(now())
}

model NotifyLog {
  id        Int      @id @default(autoincrement())
  type      String
  message   String
  success   Boolean
  createdAt DateTime @default(now())
}

model Settings {
  id           Int     @id @default(1)
  emailEnabled Boolean @default(false)
  slackEnabled Boolean @default(false)
  cronSchedule String  @default("0 */2 * * *")
}

model Subscriber {
  id         Int      @id @default(autoincrement())
  name       String
  department String
  email      String   @unique
  schedule   String   @default("immediate")
  keywords   String   @default("")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
