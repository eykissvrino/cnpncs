generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  username  String    @unique
  password  String
  name      String
  department String
  role      String    @default("user")
  active    Boolean   @default(true)
  lastLoginAt DateTime?
  loginCount Int       @default(0)
  createdAt DateTime  @default(now())
  keywords  Keyword[]
  accessLogs AccessLog[]
}

model Keyword {
  id        Int           @id @default(autoincrement())
  name      String
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())
  userId    Int?
  user      User?         @relation(fields: [userId], references: [id])
  results   CrawlResult[]

  @@unique([name, userId])
}

model CrawlResult {
  id        Int      @id @default(autoincrement())
  type      String
  title     String
  agency    String
  budget    String?
  deadline  String?
  postDate  String
  bidNumber String?  @unique
  url       String?
  rawData   String
  isNew     Boolean  @default(true)
  notified  Boolean  @default(false)
  keywordId Int?
  keyword   Keyword? @relation(fields: [keywordId], references: [id])
  createdAt DateTime @default(now())
}

model AccessLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  action    String
  detail    String?
  ip        String?
  createdAt DateTime @default(now())
}

model BidResult {
  id            Int      @id @default(autoincrement())
  bidNtceNo     String
  bidNtceOrd    String?
  bidNtceNm     String
  opengDt       String?
  sucsfbidMthdNm String?
  companyName   String?
  companyBizno  String?
  bidAmount     String?
  sucsfbidAmt   String?
  ranking       Int?
  resultType    String   @default("completed")
  agency        String?
  rawData       String
  createdAt     DateTime @default(now())

  @@unique([bidNtceNo, bidNtceOrd, companyBizno])
}

model Company {
  id          Int      @id @default(autoincrement())
  bizno       String   @unique
  name        String
  totalBids   Int      @default(0)
  totalWins   Int      @default(0)
  totalAmount String?
  lastBidDate String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

